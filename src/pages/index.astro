---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Siddharth Rajpriye"
  description="Personal blog — trekking, travel, fintech, AI, and life."
>
  <header class="site-header">
    <div class="header-inner">
      <a href="/blogs/" class="logo">Siddharth Rajpriye</a>
    </div>
  </header>

  <main class="home-main">
    <section class="hero">
      <h1 class="hero-title">Writing</h1>
      <p class="hero-sub">Trekking, travel, fintech, AI, and life — from Mumbai.</p>
    </section>

    <section class="posts-grid">
      {posts.map(post => {
        const date = post.data.pubDate.toLocaleDateString('en-US', {
          year: 'numeric', month: 'short', day: 'numeric',
        });
        return (
          <article class="post-card">
            <a href={`/blogs/blog/${post.slug}/`} class="card-link">
              {post.data.cover
                ? <div class="card-cover"><img src={post.data.cover} alt={post.data.title} /></div>
                : <div class="card-cover card-cover--gradient"></div>
              }
              <div class="card-body">
              <div class="card-tags">
                {post.data.tags.slice(0, 2).map(tag => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
              <h2 class="card-title">{post.data.title}</h2>
              <p class="card-excerpt">{post.data.description}</p>
              <div class="card-meta">
                <span>{date}</span>
                {post.data.readingTime && (
                  <span>{post.data.readingTime} min read</span>
                )}
              </div>
              </div>
            </a>
          </article>
        );
      })}
    </section>
  </main>

  <footer class="site-footer">
    <p>© {new Date().getFullYear()} Siddharth Rajpriye</p>
  </footer>
</BaseLayout>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-border);
  }
  .header-inner {
    max-width: var(--max-w-site);
    margin: 0 auto;
    padding: 0 40px;
    height: 64px;
    display: flex;
    align-items: center;
  }
  .logo {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-weight: 600;
  }

  .home-main {
    max-width: var(--max-w-site);
    margin: 0 auto;
    padding: 0 40px 80px;
  }

  .hero {
    padding: 64px 0 48px;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 48px;
  }
  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 600;
    line-height: 1.1;
    margin-bottom: 12px;
  }
  .hero-sub {
    font-size: 1.1rem;
    color: var(--color-text-light);
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2px;
  }

  .post-card {
    border: 1px solid var(--color-border);
    border-radius: 0;
    margin: -1px -1px 0 0;
    overflow: hidden;
  }
  .card-link {
    display: block;
    height: 100%;
    transition: background 0.15s;
  }
  .card-link:hover .card-body { background: var(--color-bg-alt); }

  .card-cover {
    width: 100%;
    height: 180px;
    overflow: hidden;
  }
  .card-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  .card-link:hover .card-cover img { transform: scale(1.03); }
  .card-cover--gradient {
    background: linear-gradient(135deg, #1a237e 0%, #283593 30%, #37474f 60%, #546e7a 100%);
  }
  .card-body {
    padding: 24px 28px;
    transition: background 0.15s;
  }

  .card-tags {
    display: flex;
    gap: 8px;
    margin-bottom: 12px;
  }
  .tag {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .card-title {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.3;
    margin-bottom: 10px;
    color: var(--color-text);
  }
  .card-excerpt {
    font-size: 0.9rem;
    color: var(--color-text-light);
    line-height: 1.6;
    margin-bottom: 20px;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-meta {
    display: flex;
    gap: 16px;
    font-size: 0.8rem;
    color: var(--color-text-light);
  }

  .site-footer {
    border-top: 1px solid var(--color-border);
    padding: 24px 40px;
    font-size: 0.875rem;
    color: var(--color-text-light);
    text-align: center;
  }

  @media (max-width: 640px) {
    .home-main { padding: 0 16px 60px; }
    .site-footer { padding: 24px 16px; }
    .header-inner { padding: 0 16px; }
    .posts-grid { grid-template-columns: 1fr; }
    .card-link { padding: 24px 16px; }
  }
</style>
